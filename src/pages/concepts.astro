    [180,1.002800,2.1387,6.5857,763.2,2015.3,2778.2],
    [190,1.255000,2.2338,6.5079,807.6,1978.8,2786.4],
    [200,1.553800,2.3308,6.4302,852.4,1940.7,2793.2],
    [210,1.906200,2.4248,6.3584,897.7,1900.7,2798.5],
    [220,2.318000,2.5175,6.2840,943.6,1858.5,2802.1],
    [230,2.795000,2.6101,6.2121,990.3,1813.9,2804.2],
    [240,3.346000,2.7020,6.1433,1037.5,1766.5,2803.8],
    [250,3.976000,2.7935,6.0730,1085.4,1715.9,2801.4],
    [260,4.692000,2.8838,6.0019,1134.4,1661.5,2795.6],
    [270,5.503000,2.9751,5.9301,1184.5,1604.0,2788.4],
    [280,6.417000,3.0681,5.8565,1235.0,1543.6,2778.6],
    [290,7.444000,3.1616,5.7821,1286.8,1477.1,2764.6],
    [300,8.581000,3.2552,5.7059,1341.3,1404.9,2749.0],
    [310,9.856000,3.3520,5.6265,1397.4,1325.9,2725.3],
    [320,11.274000,3.4480,5.5480,1461.1,1238.6,2699.7],
    [330,12.845000,3.5480,5.4608,1525.3,1140.3,2665.6],
    [340,14.601000,3.6577,5.3357,1594.2,1027.9,2622.0],
    [350,16.529000,3.7784,5.2112,1670.6,893.0,2563.6],
    [360,18.651000,3.9388,5.0536,1761.7,720.5,2481.0],
    [370,21.030000,4.1108,4.8012,1890.5,452.6,2333.0],
    [374.14,22.090000,4.4120,4.4120,2099.3,0,2099.3]
  ];

  // IAPWS-IF97 Region 1 coefficients [I, J, n] — IAPWS-IF97 Release 2007, Table 2
  const R1C = [
    [0,-2, 0.14632971213167],[0,-1,-0.84548187169114],[0, 0,-3.756360367204],
    [0, 1, 3.3855169168385], [0, 2,-0.95791963387872],[0, 3, 0.15772038513228],
    [0, 4,-0.016616417199501],[0, 5, 8.1214629983568e-4],
    [1,-9, 2.8319080123804e-4],[1,-7,-6.0706301565874e-4],[1,-1,-0.018990068218419],
    [1, 0,-0.032529748770505],[1, 1,-0.021841717175414],[1, 3,-5.283835796993e-5],
    [2,-3,-4.7184321073267e-4],[2, 0,-3.0001780793026e-4],[2, 1, 4.7661393906987e-5],
    [2, 3,-4.4141845330846e-6],[2,17,-7.2694996297594e-16],
    [3,-4,-3.1679644845054e-5],[3, 0,-2.8270797985312e-6],[3, 6,-8.5205128120103e-10],
    [4,-5,-2.2425281908e-6],  [4,-2,-6.5171222895601e-7],[4,10,-1.4341729937924e-13],
    [5,-8,-4.0516996860117e-7],[8,-11,-1.2734301741641e-9],[8,-6,-1.7424871230634e-10],
    [21,-29,-6.8762131295531e-19],[23,-31,1.4478307828521e-20],
    [29,-38,2.6335781662795e-23],[30,-39,-1.1947622640071e-23],
    [31,-40,1.8228094581404e-24],[32,-41,-9.3537087292458e-26],
  ];
  // Specific entropy [kJ/(kg·K)] for compressed/subcooled water
  // Valid: 0 < T_C < 350°C, P_sat(T) < P_MPa < 100 MPa
  function s_r1(T_C: number, P_MPa: number) {
    const tau = 1386.0 / (T_C + 273.15), pi = P_MPa / 16.53;
    let g = 0;
    for (let i = 0; i < R1C.length; i++) {
      const J = R1C[i][1];
      if (J !== 0) g += R1C[i][2] * Math.pow(7.1 - pi, R1C[i][0]) * J * Math.pow(tau - 1.222, J - 1);
    }
    return 0.461526 * tau * g;
  }

  const canvas = document.getElementById('tsChart') as HTMLCanvasElement | null;
  if (!canvas) return;

  function draw() {
    const dpr = window.devicePixelRatio || 1;
    const W = canvas!.parentElement!.getBoundingClientRect().width || 600;
    const H = Math.round(W * 0.58);
    canvas!.style.width = W + 'px';
    canvas!.style.height = H + 'px';
    canvas!.width = Math.round(W * dpr);
    canvas!.height = Math.round(H * dpr);
    const ctx = canvas!.getContext('2d');
    if (!ctx) return;
    const c = ctx;
    c.scale(dpr, dpr);

    const ML = 52, MR = 20, MT = 20, MB = 44;
    const SMIN = 0, SMAX = 10, TMIN = 0, TMAX = 400;

    function pt(s: number, T: number) {
      return {
        x: ML + (s - SMIN) / (SMAX - SMIN) * (W - ML - MR),
        y: MT + (TMAX - T) / (TMAX - TMIN) * (H - MT - MB)
      };
    }

    c.fillStyle = '#fff';
    c.fillRect(0, 0, W, H);

    // Grid
    c.strokeStyle = 'rgba(0,0,0,0.06)';
    c.lineWidth = 0.5;
    for (let s = 0; s <= 10; s++) {
      const p = pt(s, 0);
      c.beginPath(); c.moveTo(p.x, MT); c.lineTo(p.x, H - MB); c.stroke();
    }
    for (let T = 0; T <= 400; T += 50) {
      const p = pt(0, T);
      c.beginPath(); c.moveTo(ML, p.y); c.lineTo(W - MR, p.y); c.stroke();
    }

    // Axes
    c.strokeStyle = '#ccc'; c.lineWidth = 1;
    c.beginPath(); c.moveTo(ML, MT); c.lineTo(ML, H - MB); c.lineTo(W - MR, H - MB); c.stroke();

    // Axis labels
    const fs = Math.max(10, Math.round(W / 56));
    c.fillStyle = '#6B7280';
    c.font = fs + 'px system-ui';
    c.textAlign = 'center';
    for (let s = 0; s <= 10; s += 2) {
      const p = pt(s, TMIN);
      c.fillText(String(s), p.x, p.y + 17);
    }
    c.fillText('s  (kJ / kg·K)', ML + (W - ML - MR) / 2, H - 5);
    c.textAlign = 'right';
    for (let T = 0; T <= 400; T += 100) {
      const p = pt(SMIN, T);
      c.fillText(String(T), p.x - 6, p.y + 4);
    }
    c.save();
    c.translate(13, MT + (H - MT - MB) / 2);
    c.rotate(-Math.PI / 2);
    c.textAlign = 'center';
    c.fillText('T  (°C)', 0, 0);
    c.restore();

    // Saturation dome — sat liquid (left) and sat vapor (right)
    c.strokeStyle = '#185FA5'; c.lineWidth = 1.5;
    c.beginPath();
    SAT.forEach((r, i) => { const p = pt(r[2], r[0]); i === 0 ? c.moveTo(p.x, p.y) : c.lineTo(p.x, p.y); });
    c.stroke();
    c.beginPath();
    SAT.forEach((r, i) => { const p = pt(r[3], r[0]); i === 0 ? c.moveTo(p.x, p.y) : c.lineTo(p.x, p.y); });
    c.stroke();

    // BWR cycle: condenser 40°C, boiler ~285°C
    const T_cond = 40, T_boil = 285;

    function interp(col: number, T: number) {
      for (let i = 0; i < SAT.length - 1; i++) {
        if (SAT[i][0] <= T && T <= SAT[i+1][0]) {
          const frac = (T - SAT[i][0]) / (SAT[i+1][0] - SAT[i][0]);
          return SAT[i][col] + frac * (SAT[i+1][col] - SAT[i][col]);
        }
      }
      return SAT[SAT.length - 1][col];
    }

    const P_cond = interp(1, T_cond);
    const P_boil = interp(1, T_boil);
    const sf_cond = interp(2, T_cond);
    const sf_boil = interp(2, T_boil);
    const sg_boil = interp(3, T_boil);

    // State 1: sat liquid at condenser (on dome)
    // State 2: pump exit — isentropic, T2 = T1 + v_f·ΔP/cp ≈ T1 + 1.7°C
    // State 3: sat vapor at boiler (on dome)
    // State 4: turbine exit — wet steam inside dome at condenser T
    const s1 = sf_cond, T1 = T_cond;
    const T2 = T_cond + 0.001008 * (P_boil - P_cond) * 1000 / 4.18;
    const s2 = sf_cond;
    const s3 = sg_boil, T3 = T_boil;
    const s4 = sg_boil, T4 = T_cond;

    const p1 = pt(s1, T1), p2 = pt(s2, T2), p3 = pt(s3, T3), p4 = pt(s4, T4);
    const pBoilSatLiq = pt(sf_boil, T_boil);

    const cyc = '#993C1D';
    c.strokeStyle = cyc; c.lineWidth = 2.2; c.setLineDash([]);

    // 1→2: isentropic pump
    c.beginPath();
    c.moveTo(p1.x, p1.y);
    c.lineTo(p2.x, p2.y);
    c.stroke();

    // 2→sat-liq@boiler: IAPWS-IF97 Region 1 isobar at P_boil
    c.beginPath();
    c.moveTo(p2.x, p2.y);
    for (let T = T2 + 5; T < T_boil - 0.5; T += 5) {
      const sp = pt(s_r1(T, P_boil), T);
      c.lineTo(sp.x, sp.y);
    }
    c.lineTo(pBoilSatLiq.x, pBoilSatLiq.y);
    c.stroke();

    // sat-liq@boiler→3: isobaric vaporization (horizontal)
    c.beginPath();
    c.moveTo(pBoilSatLiq.x, pBoilSatLiq.y);
    c.lineTo(p3.x, p3.y);
    c.stroke();

    // 3→4: isentropic turbine (vertical)
    c.beginPath();
    c.moveTo(p3.x, p3.y);
    c.lineTo(p4.x, p4.y);
    c.stroke();

    // 4→1: isobaric condenser (horizontal)
    c.beginPath();
    c.moveTo(p4.x, p4.y);
    c.lineTo(p1.x, p1.y);
    c.stroke();

    function dot(p: {x: number, y: number}) {
      c.beginPath(); c.arc(p.x, p.y, 4.5, 0, 2 * Math.PI);
      c.fillStyle = cyc; c.fill();
    }
    function lbl(txt: string, p: {x: number, y: number}, dx: number, dy: number) {
      const tx = p.x + dx, ty = p.y + dy;
      c.font = 'bold 12px system-ui'; c.textAlign = 'center';
      c.fillStyle = 'rgba(255,255,255,0.92)';
      c.fillRect(tx - 9, ty - 13, 18, 17);
      c.fillStyle = cyc; c.fillText(txt, tx, ty);
    }

    dot(p1); lbl('1', p1, -14,  9);
    dot(p2); lbl('2', p2, -14, -6);
    dot(p3); lbl('3', p3,  14, -6);
    dot(p4); lbl('4', p4,  14,  9);

    c.fillStyle = '#9CA3AF'; c.font = '11px system-ui';
    c.textAlign = 'left';
    c.fillText('Turbine', p3.x + 6, (p3.y + p4.y) / 2);
    c.textAlign = 'center';
    c.fillText('Boiler', (pBoilSatLiq.x + p3.x) / 2, p3.y - 10);
    c.fillText('Condenser', (p4.x + p1.x) / 2, p4.y + 17);
  }

  draw();
  window.addEventListener('resize', () => requestAnimationFrame(draw));
})();
</script>

