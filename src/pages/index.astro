---
const base = import.meta.env.BASE_URL;

const tabs = [
  {
    id: 1,
    label: "Basic Rankine Cycle",
    slug: "tab1-basic-rankine-cycle",
    available: true,
    color: "#0ea5e9",
    desc: "Why the Rankine cycle exists, why water is the working fluid, and a tour of every industry that depends on it: nuclear, coal, gas, solar, geothermal, waste heat, and fusion.",
  },
  {
    id: 2,
    label: "Nuclear Reheat Rankine Cycle",
    slug: "tab2-nuclear-reheat-rankine-cycle",
    available: false,
    color: "#8b5cf6",
    desc: "How reheating steam between turbine stages improves efficiency and reduces moisture-related blade erosion in the low-pressure turbine.",
  },
  {
    id: 3,
    label: "Nuclear Regenerative Reheat Rankine Cycle",
    slug: "tab3-nuclear-regenerative-rankine-cycle",
    available: false,
    color: "#06b6d4",
    desc: "Feedwater heaters and regeneration: recovering heat before it reaches the condenser and its effect on cycle efficiency.",
  },
  {
    id: 4,
    label: "Real Nuclear Rankine Cycle",
    slug: "tab4-real-nuclear-rankine-cycle",
    available: false,
    color: "#10b981",
    desc: "Irreversibilities, pump and turbine isentropic efficiencies, and the gap between the ideal and real cycles.",
  },
  {
    id: 5,
    label: "Exergy & Second Law Efficiency",
    slug: "tab5-exergy-second-law",
    available: false,
    color: "#f59e0b",
    desc: "Where does the plant actually waste energy? Second law analysis, exergy destruction, and where improvements matter most.",
  },
  {
    id: 6,
    label: "Reactor & Turbine Materials",
    slug: "tab6-reactor-turbine-materials",
    available: false,
    color: "#ef4444",
    desc: "The metallurgy and materials science behind components operating under extreme temperature, pressure, and radiation.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Nuclear Rankine Cycle | Thermodynamics for Nuclear Engineers</title>
    <meta name="description" content="An interactive thermodynamics reference for students and interns at Nine Mile Point Nuclear Station. Covers the Rankine cycle from basics through exergy analysis." />
  </head>
  <body>

    <header class="site-header">
      <div class="header-inner">
        <span class="site-title">Nuclear Rankine Cycle</span>
        <span class="header-sep" aria-hidden="true"></span>
        <p class="site-subtitle">Thermodynamics for engineers &amp; nuclear interns</p>
      </div>
    </header>

    <main class="home-main">

      <!-- Hero -->
      <section class="hero">
        <div class="hero-inner">
          <div class="hero-eyebrow">Thermodynamics Reference</div>
          <h1>Nuclear Rankine Cycle</h1>
          <p class="hero-lead">
            A six-part guide to the thermodynamic cycle at the heart of every nuclear power plant.
            Built for thermodynamics students and interns at Nine Mile Point Nuclear Station in Oswego, NY.
          </p>
          <a href={`${base}tab1-basic-rankine-cycle`} class="cta-btn">
            Start with Tab 1 &rarr;
          </a>
        </div>
        <div class="hero-art" aria-hidden="true">
          <svg viewBox="0 0 200 200" fill="none">
            <!-- Stylized T-s diagram placeholder art -->
            <rect width="200" height="200" rx="16" fill="url(#hero-grad)"/>
            <!-- Dome curve (saturation curve) -->
            <path d="M30 160 Q60 60 100 40 Q140 60 170 160" stroke="rgba(56,189,248,0.5)" stroke-width="2" fill="none"/>
            <!-- Rankine cycle rectangle-ish shape inside dome -->
            <path d="M55 140 L55 90 Q80 60 100 58 Q120 60 145 90 L145 140 Q100 155 55 140Z"
                  fill="rgba(56,189,248,0.08)" stroke="rgba(56,189,248,0.6)" stroke-width="1.5"/>
            <!-- Arrows on cycle -->
            <path d="M55 110 L55 95" stroke="rgba(56,189,248,0.7)" stroke-width="2" stroke-linecap="round" marker-end="url(#arr)"/>
            <path d="M100 59 L120 64" stroke="rgba(56,189,248,0.7)" stroke-width="2" stroke-linecap="round"/>
            <path d="M145 110 L145 125" stroke="rgba(56,189,248,0.7)" stroke-width="2" stroke-linecap="round"/>
            <path d="M100 148 L80 143" stroke="rgba(56,189,248,0.7)" stroke-width="2" stroke-linecap="round"/>
            <!-- Axis labels -->
            <text x="100" y="185" text-anchor="middle" font-size="11" fill="rgba(255,255,255,0.5)" font-family="system-ui">s (kJ/kg K)</text>
            <text x="18" y="105" text-anchor="middle" font-size="11" fill="rgba(255,255,255,0.5)" font-family="system-ui" transform="rotate(-90 18 105)">T (K)</text>
            <defs>
              <linearGradient id="hero-grad" x1="0" y1="0" x2="200" y2="200" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#0f2147"/>
                <stop offset="100%" stop-color="#1d3a6e"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
      </section>

      <!-- Who this is for -->
      <section class="about-section">
        <div class="about-inner">
          <h2>Who This Is For</h2>
          <div class="about-grid">
            <div class="about-card">
              <div class="about-icon">&#127979;</div>
              <h3>Thermodynamics Students</h3>
              <p>
                If you've covered the basics of entropy and enthalpy and want to see how those
                concepts apply to a real power plant cycle, this guide builds from first principles
                to a complete analysis of the nuclear Rankine cycle.
              </p>
            </div>
            <div class="about-card">
              <div class="about-icon">&#9762;</div>
              <h3>Nuclear Interns at Nine Mile Point</h3>
              <p>
                Nine Mile Point Units 1 and 2 are GE Boiling Water Reactors on Lake Ontario.
                This guide uses NMP as the running example throughout, connecting thermodynamic
                theory directly to the plant you're working in.
              </p>
            </div>
            <div class="about-card">
              <div class="about-icon">&#128218;</div>
              <h3>Primary Textbook</h3>
              <p>
                Content follows <em>Fundamentals of Thermodynamics</em> (10th ed.) by Borgnakke
                and Sonntag, the standard reference used in many undergraduate engineering programs.
                All major claims are cited.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Tab overview -->
      <section class="tabs-section">
        <div class="tabs-inner">
          <h2>Course Sections</h2>
          <p class="tabs-intro">
            The six tabs build on each other. Start at Tab 1 and work forward, or jump to any section
            once you have the prerequisites.
          </p>
          <div class="tabs-grid">
            {tabs.map((tab) => (
              <div class={`tab-card${tab.available ? "" : " tab-card--soon"}`}>
                <div class="tab-card-num" style={`border-color: ${tab.color}; color: ${tab.color};`}>
                  {tab.id}
                </div>
                <div class="tab-card-body">
                  <div class="tab-card-label">{tab.label}</div>
                  <p class="tab-card-desc">{tab.desc}</p>
                  {tab.available ? (
                    <a href={`${base}${tab.slug}`} class="tab-card-link" style={`color: ${tab.color};`}>
                      Open Tab {tab.id} &rarr;
                    </a>
                  ) : (
                    <span class="tab-card-soon">Coming soon</span>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <footer class="home-footer">
        <p>Developed for thermodynamics students and interns at Nine Mile Point Nuclear Station, Oswego, NY.</p>
      </footer>

    </main>
  </body>
</html>

<style is:global>
  :root {
    --navy:        #0f2147;
    --navy-mid:    #162d5a;
    --accent:      #38bdf8;
    --accent-dark: #0ea5e9;
    --bg:          #f0f4f8;
    --surface:     #ffffff;
    --border:      #e2e8f0;
    --text:        #1e293b;
    --muted:       #64748b;
    --subtle:      #94a3b8;
    --sans:        system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
    --radius:      8px;
    --radius-lg:   12px;
    --header-h:    52px;
    --shadow-sm:   0 1px 3px rgba(0,0,0,.09), 0 1px 2px rgba(0,0,0,.06);
    --shadow-md:   0 4px 8px rgba(0,0,0,.08), 0 2px 4px rgba(0,0,0,.05);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    line-height: 1.65;
    font-size: 16px;
  }

  /* Header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-h);
    background: var(--navy);
    border-bottom: 1px solid rgba(255,255,255,.08);
    display: flex;
    align-items: center;
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: 0 1.5rem;
    width: 100%;
  }
  .site-title {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -.01em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .header-sep {
    width: 1px;
    height: 18px;
    background: rgba(255,255,255,.2);
    flex-shrink: 0;
  }
  .site-subtitle {
    font-size: .8rem;
    color: var(--subtle);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Home layout */
  .home-main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  /* Hero */
  .hero {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 3rem;
    align-items: center;
    padding: 4rem 0 3.5rem;
    border-bottom: 1px solid var(--border);
  }
  .hero-eyebrow {
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--accent-dark);
    margin-bottom: .875rem;
  }
  .hero h1 {
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -.03em;
    color: var(--navy);
    line-height: 1.05;
    margin-bottom: 1rem;
  }
  .hero-lead {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 1.75rem;
  }
  .cta-btn {
    display: inline-block;
    background: var(--navy);
    color: #fff;
    text-decoration: none;
    padding: .7rem 1.5rem;
    border-radius: var(--radius);
    font-size: .9rem;
    font-weight: 700;
    letter-spacing: .01em;
    transition: background .15s;
  }
  .cta-btn:hover { background: var(--navy-mid); }

  .hero-art {
    width: 100%;
    max-width: 280px;
  }
  .hero-art svg {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  /* About section */
  .about-section {
    padding: 3.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .about-inner h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 1.75rem;
  }
  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .about-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  .about-icon {
    font-size: 1.75rem;
    margin-bottom: .75rem;
    line-height: 1;
  }
  .about-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: .5rem;
  }
  .about-card p {
    font-size: .88rem;
    color: var(--muted);
    line-height: 1.65;
  }
  .about-card p em { font-style: italic; }

  /* Tabs section */
  .tabs-section {
    padding: 3.5rem 0;
  }
  .tabs-inner h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: .5rem;
  }
  .tabs-intro {
    font-size: .95rem;
    color: var(--muted);
    margin-bottom: 1.75rem;
  }
  .tabs-grid {
    display: flex;
    flex-direction: column;
    gap: .875rem;
  }
  .tab-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow-sm);
    transition: box-shadow .15s;
  }
  .tab-card:hover { box-shadow: var(--shadow-md); }
  .tab-card--soon {
    opacity: .65;
  }
  .tab-card-num {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius);
    border: 2px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 800;
    margin-top: 2px;
  }
  .tab-card-body { flex: 1; }
  .tab-card-label {
    font-size: 1rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: .35rem;
  }
  .tab-card-desc {
    font-size: .875rem;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: .625rem;
  }
  .tab-card-link {
    font-size: .82rem;
    font-weight: 700;
    text-decoration: none;
  }
  .tab-card-link:hover { text-decoration: underline; }
  .tab-card-soon {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--subtle);
    background: rgba(0,0,0,.04);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2px 7px;
    display: inline-block;
  }

  /* Footer */
  .home-footer {
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
    margin-top: 2rem;
    font-size: .8rem;
    color: var(--subtle);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .home-main { padding: 0 1.25rem 3rem; }
    .hero {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2.5rem 0 2.5rem;
    }
    .hero-art { max-width: 200px; }
    .hero h1 { font-size: 2.25rem; }
    .header-sep, .site-subtitle { display: none; }
  }

  @media (max-width: 480px) {
    .hero h1 { font-size: 1.85rem; }
    .tab-card { flex-direction: column; gap: .75rem; }
    .tab-card-num { width: 2rem; height: 2rem; font-size: .9rem; }
  }
</style>
